# EcoClaw-Bench local environment
# Copy this file to .env and fill your real values.

# Your gateway-compatible API endpoint
ECOCLAW_BASE_URL=https://concept.dica.cc/llm

# Your API key (keep local, never commit)
ECOCLAW_API_KEY=sk-xxx

# Model alias or full model id. Alias examples:
# gpt-5, gpt-5-mini, gpt-5-nano, gpt-4o, o3, claude-sonnet-4, claude-opus-4.1
# Optional: prefix for OpenAI-family aliases.
# aliases like gpt-5-mini -> xxx/gpt-5-mini.
ECOCLAW_OPENAI_PROVIDER=xxx
ECOCLAW_MODEL=gpt-5-mini

# Judge model alias or full id
ECOCLAW_JUDGE=claude-opus-4.1

# Optional PinchBench options
ECOCLAW_SUITE=automated-only
ECOCLAW_RUNS=3
ECOCLAW_PARALLEL=1
ECOCLAW_TIMEOUT_MULTIPLIER=1.0

# Multi-agent (subagent) options
# Set to true to enable multi-agent mode by default
ECOCLAW_ENABLE_MULTI_AGENT=false
# Comma-separated worker roles (coordinator is always created).
# Ignored when ECOCLAW_AGENT_CONFIG is set.
ECOCLAW_MULTI_AGENT_ROLES=researcher,coder
# Path to a JSON file defining per-agent models, skills, and allowAgents.
# When set, overrides ECOCLAW_MULTI_AGENT_ROLES and forces multi-agent mode on.
# Example: experiments/agent-config/pinchbench_agents.json
ECOCLAW_AGENT_CONFIG=
# Subagent thinking level: off, low, medium, high (only used without agent-config)
ECOCLAW_SUBAGENT_THINKING=medium
# Max concurrent subagent runs (only used without agent-config)
ECOCLAW_SUBAGENT_MAX_CONCURRENT=4

# Optional runtime prompt/context limits per dataset
# claw_eval prefers CLAW_EVAL_* and falls back to PINCHBENCH_* if unset
CLAW_EVAL_MAX_MSG_CHARS=32000
CLAW_EVAL_CONTEXT_HASH_PREFIX_CHARS=1024
CLAW_EVAL_CONTEXT_RECENT_MESSAGES=4
#CLAW_EVAL_OPENCLAW_AGENT_LOCK_FILE=/tmp/claw_eval_openclaw_agents.lock

# frontierscience prefers FRONTIERSCIENCE_* and falls back to PINCHBENCH_* if unset
FRONTIERSCIENCE_MAX_MSG_CHARS=32000
FRONTIERSCIENCE_CONTEXT_HASH_PREFIX_CHARS=1024
FRONTIERSCIENCE_CONTEXT_RECENT_MESSAGES=4
#FRONTIERSCIENCE_OPENCLAW_AGENT_LOCK_FILE=/tmp/frontierscience_openclaw_agents.lock

# pinchbench runtime prompt/context limits
PINCHBENCH_MAX_MSG_CHARS=32000
PINCHBENCH_CONTEXT_HASH_PREFIX_CHARS=1024
PINCHBENCH_CONTEXT_RECENT_MESSAGES=4
#PINCHBENCH_OPENCLAW_AGENT_LOCK_FILE=/tmp/pinchbench_openclaw_agents.lock
