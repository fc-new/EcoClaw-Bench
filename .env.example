# EcoClaw-Bench local environment
# Copy this file to .env and fill your real values.

# Your gateway-compatible API endpoint
ECOCLAW_BASE_URL=https://concept.dica.cc/llm

# Your API key (keep local, never commit)
ECOCLAW_API_KEY=sk-xxx

# Model alias or full model id. Alias examples:
# gpt-5, gpt-5-mini, gpt-5-nano, gpt-4o, o3, claude-sonnet-4, claude-opus-4.1
ECOCLAW_MODEL=gpt-5-mini

# Judge model alias or full id
ECOCLAW_JUDGE=claude-opus-4.1

# Optional PinchBench options
ECOCLAW_SUITE=automated-only
ECOCLAW_RUNS=3
ECOCLAW_PARALLEL=1
ECOCLAW_TIMEOUT_MULTIPLIER=1.0
