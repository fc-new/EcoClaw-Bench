{
  "agents": {
    "defaults": {
      "model": {
        "primary": "dmxapi/gpt-5-mini",
        "fallbacks": []
      },
      "subagents": {
        "model": "dmxapi/gpt-5-mini",
        "thinking": "off",
        "maxConcurrent": 3,
        "archiveAfterMinutes": 30
      },
      "sandbox": {
        "sessionToolsVisibility": "spawned"
      }
    },
    "list": [
      {
        "id": "coordinator",
        "default": true,
        "name": "Orchestrator",
        "model": "dmxapi/gpt-5.4-mini",
        "skills": [
          "workflow-orchestration-patterns",
          "summarize",
          "session-logs",
          "deep-research"
        ],
        "subagents": {
          "allowAgents": [
            "researcher",
            "reviewer"
          ]
        }
      },
      {
        "id": "researcher",
        "name": "Research Agent",
        "model": "dmxapi/gpt-5-mini",
        "skills": [
          "tavily",
          "academic-researcher",
          "sympy",
          "hypothesis-generation",
          "plotly",
          "math-olympiad"
        ]
      },
      {
        "id": "reviewer",
        "name": "Science Reviewer",
        "model": "dmxapi/gpt-5-mini",
        "skills": [
          "scientific-writing",
          "citation-management",
          "data-analyst",
          "summarize"
        ]
      }
    ]
  },
  "tools": {
    "subagents": {
      "tools": {
        "deny": [
          "browser"
        ]
      }
    }
  },
  "commands": {
    "restart": true
  }
}