{
  "agents": {
    "defaults": {
      "model": {
        "primary": "dmxapi/gpt-5-mini",
        "fallbacks": []
      },
      "subagents": {
        "model": "dmxapi/gpt-5-mini",
        "thinking": "off",
        "maxConcurrent": 4,
        "archiveAfterMinutes": 30
      },
      "sandbox": {
        "sessionToolsVisibility": "spawned"
      }
    },
    "list": [
      {
        "id": "coordinator",
        "default": true,
        "name": "Orchestrator",
        "model": "dmxapi/gpt-5.4-mini",
        "skills": [
          "workflow-orchestration-patterns",
          "summarize",
          "session-logs",
          "saga-orchestration"
        ],
        "subagents": {
          "allowAgents": [
            "coder",
            "researcher",
            "reviewer"
          ]
        }
      },
      {
        "id": "coder",
        "name": "Coding Agent",
        "model": "dmxapi/gpt-5-mini",
        "skills": [
          "coding-agent",
          "code-style",
          "github",
          "debugger",
          "docker-patterns"
        ]
      },
      {
        "id": "researcher",
        "name": "Research Agent",
        "model": "dmxapi/gpt-5-mini",
        "skills": [
          "tavily",
          "deep-research",
          "search-first",
          "data-analyst"
        ]
      },
      {
        "id": "reviewer",
        "name": "Reviewer",
        "model": "dmxapi/gpt-5-mini",
        "skills": [
          "backend-code-review",
          "healthcheck",
          "summarize",
          "session-logs"
        ]
      }
    ]
  },
  "tools": {
    "subagents": {
      "tools": {
        "deny": [
          "browser"
        ]
      }
    }
  },
  "commands": {
    "restart": true
  }
}