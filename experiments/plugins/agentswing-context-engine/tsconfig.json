{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "openclaw/plugin-sdk/plugin-entry": ["./typings/openclaw.d.ts"],
      "openclaw/plugin-sdk": ["./typings/openclaw.d.ts"]
    }
  },
  "include": ["index.ts", "src/**/*.ts", "typings/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
