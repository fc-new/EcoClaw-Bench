{
  "id": "pichay-context-engine",
  "name": "Pichay Context Engine",
  "description": "Pichay paging and conversation compaction for OpenClaw",
  "version": "0.1.0",
  "kind": "context-engine",
  "main": "./index.js",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "adapterBaseUrl": {
        "type": "string",
        "default": "http://127.0.0.1:19012"
      },
      "triggerMode": {
        "type": "string",
        "enum": [
          "token-ratio",
          "turn-count"
        ],
        "default": "token-ratio"
      },
      "triggerRatio": {
        "type": "number",
        "minimum": 0.01,
        "maximum": 0.99,
        "default": 0.4
      },
      "triggerTurnCount": {
        "type": "integer",
        "minimum": 1,
        "maximum": 200,
        "default": 10
      },
      "ageThreshold": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 4
      },
      "minEvictSize": {
        "type": "integer",
        "minimum": 64,
        "default": 500
      },
      "preserveRecent": {
        "type": "integer",
        "minimum": 2,
        "default": 12
      },
      "minTextChars": {
        "type": "integer",
        "minimum": 200,
        "default": 2000
      },
      "maxSummaryChars": {
        "type": "integer",
        "minimum": 100,
        "default": 300
      },
      "enableModelSummary": {
        "type": "boolean",
        "default": false
      },
      "requestTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "default": 30000
      }
    }
  }
}
